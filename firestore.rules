rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Signed-in users may read/write only their own profile under user_stats.
    // Path: users/{firebaseAuthUid}/user_stats/profile (see userStatsFirestore.ts)
    match /users/{userId}/user_stats/{docId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // College LMS mock integration + imported calendar events (see lmsFirestore.ts)
    match /users/{userId}/lms_integration/{docId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    match /users/{userId}/lms_calendar_events/{eventId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Microsoft 365 / Outlook calendar import (see microsoftCalendarFirestore.ts)
    match /users/{userId}/microsoft_calendar_integration/{docId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    match /users/{userId}/microsoft_calendar_events/{eventId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Google Workspace / Google Calendar import (see googleCalendarFirestore.ts)
    match /users/{userId}/google_calendar_integration/{docId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    match /users/{userId}/google_calendar_events/{eventId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Everything else: deny (explicit; paths with no matching rule are also denied by default)
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
