# Copy to backend/.env — never commit .env
# Firebase Console → Project settings → Your apps → Web app.

FIREBASE_WEB_API_KEY=your_web_api_key
FIREBASE_WEB_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_WEB_PROJECT_ID=your-project-id
FIREBASE_WEB_STORAGE_BUCKET=your-project.firebasestorage.app
FIREBASE_WEB_MESSAGING_SENDER_ID=123456789
FIREBASE_WEB_APP_ID=1:123456789:web:abcdef
FIREBASE_WEB_MEASUREMENT_ID=G-XXXXXXXXXX

# Firebase Admin — required for POST /api/auth/verify (dashboard “token check”)
# Option A: one line of JSON (private_key must use \n for newlines, not real line breaks)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
#
# Option B: path to the downloaded key file (relative to backend/ or absolute)
# FIREBASE_SERVICE_ACCOUNT_PATH=serviceAccount.json
#
# Option C: standard Google env pointing at the key file
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/serviceAccount.json

# Must match Vite’s proxy (frontend reads this file) unless you set VITE_DEV_API_PORT in frontend/.env
PORT=4000
